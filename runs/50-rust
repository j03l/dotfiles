#!/usr/bin/env bash
set -euo pipefail

paru -S --needed --noconfirm rustup stylua

# Ensure a default toolchain is installed
if ! rustup show active-toolchain &>/dev/null; then
    rustup default stable
fi

# claude-tmux is not packaged — install via cargo
if ! command -v claude-tmux &>/dev/null; then
    echo "Installing claude-tmux via cargo..."
    cargo install claude-tmux
fi
