#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["evdev"]
# ///
"""Map Keychron Ultra-Link 8K horizontal scroll to system volume."""

import subprocess
import evdev
from evdev import ecodes

DEVICE = "/dev/input/by-id/usb-Keychron_Keychron_Ultra-Link_8K-event-mouse"
STEP = "2%"


def set_volume(direction):
    subprocess.Popen(
        ["wpctl", "set-volume", "-l", "1.0", "@DEFAULT_AUDIO_SINK@", f"{STEP}{direction}"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def main():
    device = evdev.InputDevice(DEVICE)
    print(f"Listening: {device.name} ({device.path})")

    for event in device.read_loop():
        if event.type == ecodes.EV_REL and event.code == ecodes.REL_HWHEEL:
            set_volume("+" if event.value > 0 else "-")


if __name__ == "__main__":
    main()
