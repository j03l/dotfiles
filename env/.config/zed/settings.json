  "languages": {
    "Python": {
      "language_servers": ["ruff", "ty", "!pyright", "!basedpyright"],
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
      "format_on_save": "on",
    },
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 120,
        },
      },
    },
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": false,
  "ui_font_size": 20.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "Tokyo Night Light",
    "dark": "Tokyo Night Storm",
  },
}
