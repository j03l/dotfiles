{
  "cli_default_open_behavior": "new_window",
  "show_edit_predictions": false,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "preferred_line_length": 100,
  "ui_font_weight": 400.0,
  "buffer_font_weight": 400.0,
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_status_icon": true,
  },
  "status_bar": {
    "show_active_file": false,
    "active_encoding_button": "enabled",
  },
  "agent_ui_font_size": 16.0,
  "proxy": "",
  "project_panel": {
    "hide_hidden": false,
    "git_status_indicator": true,
    "entry_spacing": "standard",
    "dock": "right",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": true,
      "effort": "high"
    },
    "show_turn_stats": true,
    "use_modifier_to_send": false,
    "expand_terminal_card": false,
    "thinking_display": "always_collapsed",
    "play_sound_when_agent_done": "never",
    "single_file_review": true,
    "dock": "left",
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": false,
    },
    "model_parameters": [],
  },
  "show_wrap_guides": true,
  "search": {
    "include_ignored": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "file_scan_exclusions": [
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/__pycache__",
    "**/*.pyc",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.pytest_cache",
    "**/node_modules",
  ],
  "auto_update": false,
  "auto_install_extensions": {
    "toml": true,
    "dockerfile": true,
    "html": true,
    "ruff": true,
    "ty": true,
    "tokyo-night": true,
    "rose-pine": true,
    "zed-icons-colored-theme": true,
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "soft_wrap": "editor_width",
  "use_smartcase_search": true,
  "calls": {
    "mute_on_join": true,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "terminal": {
    "dock": "bottom",
    "flexible": true,
    "show_count_badge": true,
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_size": 14.0,
    "font_family": "Cascadia Code NF",
    "copy_on_select": true,
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "ui_font_family": "Cascadia Code",
  "buffer_line_height": "standard",
  "buffer_font_family": "Cascadia Mono NF",
  "ssh_connections": [
