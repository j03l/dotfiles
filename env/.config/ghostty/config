# Font
font-family = Cascadia Mono NF
font-size = 12

# Theme & background
theme = TokyoNight Night
background-opacity = 0.95

# Window
# gtk-titlebar = false  # doesn't work on KDE
window-padding-x = 5
window-padding-y = 5
confirm-close-surface = false

# Cursor
cursor-style = bar
cursor-style-blink = false

# Shell integration (minimal, like Prime)
shell-integration-features = no-cursor,no-sudo,no-title

# Links
link-url = true

# No bell
# Ghostty has no audible bell by default

# Unbind Ctrl+Enter fullscreen
keybind = ctrl+enter=unbind

# Fullscreen toggle
keybind = f11=toggle_fullscreen

# Tab bar (tokyonight-night, matching tmux)
window-theme = ghostty
window-titlebar-background = #16161e
window-titlebar-foreground = #a9b1d6
gtk-wide-tabs = false
adw-toolbar-style = flat
gtk-custom-css = tabs.css

# Copy & paste
copy-on-select = clipboard
