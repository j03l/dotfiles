export XDG_CONFIG_HOME=$HOME/.config
export GIT_EDITOR=nvim
export DOTFILES="$HOME/dotfiles"
export BWS_ACCESS_TOKEN=$(kwallet-query -f Passwords -r bws-access-token kdewallet 2>/dev/null)

# tmux-sessionizer keybinds
bindkey -s ^f "tmux-sessionizer\n"

# Session bookmark goto (Alt + h/j/k/l)
bindkey -s '\eh' "tmux-bookmark goto 1\n"
bindkey -s '\ej' "tmux-bookmark goto 2\n"
bindkey -s '\ek' "tmux-bookmark goto 3\n"
bindkey -s '\el' "tmux-bookmark goto 4\n"
