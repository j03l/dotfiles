# GitHub - uses signing key
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/github_signing
  IdentitiesOnly yes

# KDE GitLab
Host invent.kde.org
  HostName invent.kde.org
  User git
  IdentityFile ~/.ssh/github_signing
  IdentitiesOnly yes

# Default for all other hosts - uses remote login key
Host *
  IdentityFile ~/.ssh/github_signing
  IdentitiesOnly yes
  ServerAliveInterval 30
  ServerAliveCountMax 3
  TCPKeepAlive yes

