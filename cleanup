#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"

dry_run=0
[[ "${1:-}" == "--dry" ]] && dry_run=1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() { echo -e "$1"; }

remove_symlink() {
    local target="$1"
    if [[ -L "$target" ]]; then
        local points_to
        points_to=$(readlink "$target")
        if [[ "$points_to" == "$DOTFILES"* ]]; then
            if [[ $dry_run == 1 ]]; then
                log "${YELLOW}[DRY_RUN]${NC} would remove symlink: $target -> $points_to"
            else
                rm "$target"
                log "${GREEN}removed${NC} symlink: $target"
            fi
        else
            log "${YELLOW}skipped${NC} $target (points to $points_to, not this dotfiles repo)"
        fi
    elif [[ -e "$target" ]]; then
        log "${YELLOW}skipped${NC} $target (exists but is not a symlink — not ours)"
    fi
}

remove_file() {
    local target="$1"
    if [[ -e "$target" ]]; then
        if [[ $dry_run == 1 ]]; then
            log "${YELLOW}[DRY_RUN]${NC} would remove: $target"
        else
            rm -f "$target"
            log "${GREEN}removed${NC} $target"
        fi
    fi
}

remove_dir() {
    local target="$1"
    if [[ -d "$target" ]]; then
        if [[ $dry_run == 1 ]]; then
            log "${YELLOW}[DRY_RUN]${NC} would remove dir: $target"
        else
            rm -rf "$target"
            log "${GREEN}removed${NC} dir: $target"
        fi
    fi
}

echo "=== Dotfiles cleanup ==="
echo "This removes symlinks and configs deployed by ./install"
echo ""

if [[ $dry_run == 0 ]]; then
    read -rp "Continue? [y/N] " answer
    if [[ ! "$answer" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi
    echo ""
fi

# --- Config symlinks (from deploy) ---
log "${RED}--- Config symlinks ---${NC}"
remove_symlink "$HOME/.config/nvim"
remove_symlink "$HOME/.config/ghostty"
remove_symlink "$HOME/.config/kitty"
remove_symlink "$HOME/.config/glow"
remove_symlink "$HOME/.config/tmux"
remove_symlink "$HOME/.config/tmux-sessionizer"
remove_symlink "$HOME/.gitconfig"
remove_symlink "$HOME/.zshrc"
remove_symlink "$HOME/.zsh_profile"
remove_symlink "$HOME/.ssh/config"

# --- bin/ scripts ---
log ""
log "${RED}--- ~/.local/bin/ scripts ---${NC}"
for script in "$DOTFILES"/bin/*; do
    [[ -f "$script" ]] || continue
    name=$(basename "$script")
    [[ "$name" == "README.md" ]] && continue
    remove_symlink "$HOME/.local/bin/$name"
done

# --- Secrets (if deployed) ---
log ""
log "${RED}--- Secret files ---${NC}"
remove_file "$HOME/.gitconfig.local"
remove_file "$HOME/.git-credentials"
remove_file "$HOME/.config/gh/hosts.yml"
remove_file "$HOME/.config/github-copilot/apps.json"
remove_file "$HOME/.config/rclone/rclone.conf"
remove_file "$HOME/.config/gitlab/token"
remove_file "$HOME/.config/ynab/token"
remove_file "$HOME/.bootdev.yaml"

# --- Runtime artifacts ---
log ""
log "${RED}--- Runtime artifacts ---${NC}"
remove_dir "$HOME/.tmux"
remove_dir "$HOME/.local/share/nvim"
remove_dir "$HOME/.local/state/nvim"
remove_dir "$HOME/.cache/nvim"
remove_dir "$HOME/.vim/undodir"
remove_file "$HOME/.zsh_history"

echo ""
log "${GREEN}Cleanup complete.${NC}"
if [[ $dry_run == 1 ]]; then
    echo "(dry run — nothing was actually removed)"
fi
echo ""
echo "Not removed (clean up manually if desired):"
echo "  - Installed packages (paru, zsh, neovim, tmux, ghostty, rust, node, go, etc.)"
echo "  - Docker service and containers"
echo "  - Rust toolchain (~/.rustup, ~/.cargo)"
echo "  - Go installation (~/.local/opt/go, ~/go)"
echo "  - Node/npm global packages"
echo "  - uv (~/.local/bin/uv, ~/.cache/uv)"
echo "  - oh-my-zsh (/usr/share/oh-my-zsh)"
echo "  - This dotfiles repo itself"
