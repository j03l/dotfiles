#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
MAPPING="$DOTFILES/secrets.env"
dry_run=0
[[ "${1:-}" == "--dry" ]] && dry_run=1

if [[ -z "${BWS_ACCESS_TOKEN:-}" ]]; then
    echo "ERROR: BWS_ACCESS_TOKEN is not set."
    echo ""
    echo "Setup:"
    echo "  1. Open Bitwarden Secrets Manager → Machine accounts → generate an access token"
    echo "  2. Store it in KDE Wallet:"
    echo "       echo -n 'your-token' | kwallet-query -f Passwords -w bws-access-token kdewallet"
    echo "  3. Open a new shell (loads token from .zsh_profile) or export manually:"
    echo "       export BWS_ACCESS_TOKEN=\$(kwallet-query -f Passwords -r bws-access-token kdewallet)"
    echo "  4. Re-run this script"
    exit 1
fi

if ! command -v bws &>/dev/null; then
    echo "ERROR: bws is not installed."
    exit 1
fi

if ! command -v jq &>/dev/null; then
    echo "ERROR: jq is not installed."
    exit 1
fi

errors=0

while IFS= read -r line; do
    # skip comments and blank lines
    [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

    read -r uuid target perms <<< "$line"
    target="${target/#\~/$HOME}"

    if [[ "$dry_run" == "1" ]]; then
        name=$(bws secret get "$uuid" -o json 2>/dev/null | jq -r '.key // empty') || name="<fetch failed>"
        echo "[DRY_RUN] $name -> $target (mode $perms)"
        continue
    fi

    json=$(bws secret get "$uuid" -o json 2>/dev/null) || true
    value=$(printf '%s' "$json" | jq -r '.value // empty')
    if [[ -z "$value" ]]; then
        echo "FAIL: could not fetch secret $uuid"
        errors=$((errors + 1))
        continue
    fi

    name=$(printf '%s' "$json" | jq -r '.key // empty')
    mkdir -p "$(dirname "$target")"
    printf '%s\n' "$value" > "$target"
    chmod "$perms" "$target"
    echo "ok: $name -> $target"
done < "$MAPPING"

if [[ "$errors" -gt 0 ]]; then
    echo ""
    echo "$errors secret(s) failed. Check UUIDs and BWS_ACCESS_TOKEN."
    exit 1
fi

echo "secrets complete."
