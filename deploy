#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
export DOTFILES

dry_run="0"
[[ "${1:-}" == "--dry" ]] && dry_run="1"

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# Read or prompt for environment
selected_env=""
[[ -f "$HOME/.dotfiles-env" ]] && selected_env=$(cat "$HOME/.dotfiles-env")
if [[ -n "$selected_env" ]]; then
    echo "Current environment: $selected_env"
    read -rp "Keep current? [Y/n] " answer
    if [[ ! "${answer:-y}" =~ ^[Yy]$ ]]; then
        selected_env=""
    fi
fi
if [[ -z "$selected_env" ]]; then
    echo "Select environment:"
    select env in home work; do
        if [[ -n "$env" ]]; then
            selected_env="$env"
            break
        fi
    done
fi
echo "$selected_env" > "$HOME/.dotfiles-env"
echo "Environment: $selected_env"
echo ""

log() {
    if [[ $dry_run == "1" ]]; then
        echo "[DRY_RUN]: $1"
    else
        echo "$1"
    fi
}

# Warn if target is a real file/dir (not a symlink) — may contain local changes
check_overwrite() {
    local dest="$1"
    if [[ -e "$dest" && ! -L "$dest" ]]; then
        echo "WARNING: $dest is a real file/directory, not a symlink."
        read -rp "Overwrite? [y/N] " answer
        if [[ ! "$answer" =~ ^[Yy]$ ]]; then
            echo "skip: $dest"
            return 1
        fi
    fi
    return 0
}

# Remove target (file, dir, or stale symlink) then symlink
link_dir() {
    local src="$1" dest="$2"
    if [[ -L "$dest" && "$(readlink "$dest")" == "$src" ]]; then
        log "ok (already linked) $dest -> $src"
        return
    fi
    if [[ $dry_run == "0" ]]; then
        check_overwrite "$dest" || return 0
    fi
    log "rm -rf $dest"
    log "ln -s  $src -> $dest"
    if [[ $dry_run == "0" ]]; then
        rm -rf "$dest"
        mkdir -p "$(dirname "$dest")"
        ln -s "$src" "$dest"
    fi
}

link_file() {
    local src="$1" dest="$2"
    if [[ -L "$dest" && "$(readlink "$dest")" == "$src" ]]; then
        log "ok (already linked) $dest -> $src"
        return
    fi
    if [[ $dry_run == "0" ]]; then
        check_overwrite "$dest" || return 0
    fi
    log "rm -f $dest"
    log "ln -s $src -> $dest"
    if [[ $dry_run == "0" ]]; then
        mkdir -p "$(dirname "$dest")"
        rm -f "$dest"
        ln -s "$src" "$dest"
    fi
}

echo "=== deploy: nvim ==="
link_dir "$DOTFILES/nvim" "$XDG_CONFIG_HOME/nvim"

echo "=== deploy: env/.config/* ==="
for dir in "$DOTFILES"/env/.config/*/; do
    name=$(basename "$dir")
    link_dir "${dir%/}" "$XDG_CONFIG_HOME/$name"
done

echo "=== deploy: gitconfig ==="
link_file "$DOTFILES/env/.gitconfig" "$HOME/.gitconfig"

echo "=== deploy: zsh dotfiles ==="
link_file "$DOTFILES/env/.zshrc" "$HOME/.zshrc"
link_file "$DOTFILES/env/.zsh_profile" "$HOME/.zsh_profile"

echo "=== deploy: ssh config ==="
mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"
link_file "$DOTFILES/env/.ssh/config" "$HOME/.ssh/config"

echo "=== deploy: bin/ ==="
mkdir -p "$HOME/.local/bin"
for script in "$DOTFILES"/bin/*; do
    [[ -f "$script" ]] || continue
    name=$(basename "$script")
    [[ "$name" == "README.md" ]] && continue
    link_file "$script" "$HOME/.local/bin/$name"
done

log "deploy complete."
